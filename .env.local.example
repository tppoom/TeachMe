# SQLite database path — points to the local database file
DATABASE_URL=file:./teachme.db

# API keys — optional if you use a local CLI provider (Gemini CLI, Claude Code, Codex)
# You can also enter these in the Settings page instead of setting them here.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
