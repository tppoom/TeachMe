generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lesson {
  id             String   @id @default(cuid())
  title          String
  topic          String
  priorKnowledge String?
  goals          String?
  provider       String
  content        Json
  atlas          Json?
  syllabus       Json?
  language       String   @default("English")
  sourceUrls     String   @default("[]")
  sourceFiles    String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Config {
  key   String @id
  value String
}
